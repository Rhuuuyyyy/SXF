# SXFp Backend — environment variables template
# Copy this file to `.env` and override values locally. Never commit `.env`.

APP_NAME="SXFp Backend"
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

API_PREFIX=/api/v1

# Replace with a strong random value (>=32 bytes) before any non-local deploy.
SECRET_KEY=change-me-in-environment

# JSON array of allowed CORS origins (required by pydantic-settings v2).
# Development: include the Next.js dev server.
# Production: replace with your deployed frontend domain.
CORS_ORIGINS=["http://localhost:3000"]
